# =====================================================================
# MB BANK WEBHOOK GATEWAY - ENVIRONMENT VARIABLES TEMPLATE
# Sao chép file này thành .env để chạy local, hoặc nhập lên Vercel.
# =====================================================================

# 1. Database connection URL (Bắt buộc khi deploy lên Vercel Serverless)
# Lấy từ Supabase Dashboard: Settings > Database > Connection string (URI)
DATABASE_URL="postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_ID].supabase.co:5432/postgres"

# 2. Mã khóa bảo mật dành cho Cron Job quét giao dịch tự động (Tùy chọn)
# Vercel Cron sẽ gửi Bearer Token khớp với giá trị này để kích hoạt quét
CRON_SECRET="your-secure-cron-secret-token"

# 3. Mật khẩu mặc định truy cập trang Admin Dashboard (Mặc định là admin123 nếu để trống)
ADMIN_PASSWORD="admin123"

# 4. Các biến môi trường tùy chọn (Có thể cài trực tiếp trên Admin Dashboard)
MB_USERNAME=""
MB_PASSWORD=""
MB_ACCOUNT_NUMBER=""
DEFAULT_CALLBACK_URL=""
CALLBACK_SECRET="super-secret-callback-token"

# 5. Đường dẫn file DB SQLite (Chỉ sử dụng khi chạy ở local và không cấu hình DATABASE_URL)
SQLITE_DB_PATH="db.sqlite"
